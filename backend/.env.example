# Copy to .env and fill in. Every value here is optional — SiteMind runs fully
# offline (LLM_PROVIDER=offline, the default) with no keys at all.

# offline | codex | openai | anthropic
LLM_PROVIDER=offline

# codex: needs `codex login` done on this machine (no API key). See docs/CODEX_SETUP.md.
CODEX_MODEL=gpt-5.4

# openai: needs an API key.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.1

# anthropic: needs an API key.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_SMART=claude-3-5-sonnet-latest

# Required for Copilot's semantic retrieval (app/embeddings.py calls the HF
# Inference API instead of loading the model in-process). Free token from
# https://huggingface.co/settings/tokens. Independent of LLM_PROVIDER above.
# HF_TOKEN=

# Langfuse (optional, real tracing) — free tier at https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# CORS — comma-separated allowed frontend origins. Defaults to localhost:3000.
# In production (e.g. Render), set to your deployed frontend's URL:
# ALLOWED_ORIGINS=https://sitemind.vercel.app,http://localhost:3000

# Standalone standards/company-upload retrieval package (Phase 3). Off by
# default — set to 1 to mount /api/retrieval/* endpoints.
RETRIEVAL_ENABLED=0
# local | openai — embeddings backend for that package (default: local).
# RETRIEVAL_EMBEDDINGS_PROVIDER=local

# Codebook MCP client (standards-service/, a separate process — see
# docs/BUILD_PLAN_CODEBOOK.md). Off by default — set to 1 to mount
# /api/codebook/* endpoints, which proxy to Codebook's own MCP server. Only
# takes effect if standards-service/run.sh is actually running.
CODEBOOK_ENABLED=0
# CODEBOOK_MCP_URL=http://127.0.0.1:8010/mcp
