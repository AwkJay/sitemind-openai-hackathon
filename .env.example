# SiteMind environment. Copy to backend/.env to enable a live LLM for prose + unseen copilot questions.
# The demo runs fully WITHOUT any of this (LLM_PROVIDER=offline): compliance pass/fail + citations are
# ALWAYS deterministic, and prose/answers come from cached fixtures. Offline is the safest stage default.

# Which LLM backend writes prose / answers unseen questions:
#   offline   (default) — no network; deterministic seeds + cached fixtures
#   codex     — OpenAI Codex SDK via local ChatGPT login (NO API key). See docs/CODEX_SETUP.md
#   openai    — OpenAI API (needs OPENAI_API_KEY)
#   anthropic — Anthropic API (needs ANTHROPIC_API_KEY)
LLM_PROVIDER=offline

# --- codex (ChatGPT login; run `codex login` once, then `pip install openai-codex`) ---
CODEX_MODEL=gpt-5.4

# --- openai ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# --- anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SMART=claude-opus-4-8

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
